<% content_for :title, "#{@title} — EPS Docs" %>

<div class="max-w-6xl mx-auto px-4 py-8 flex gap-10">

  <%# Sidebar %>
  <nav class="w-56 shrink-0">
    <div class="sticky top-8">
      <%= link_to "← Registry", root_path, class: "text-xs text-gray-400 hover:text-black mb-6 block" %>
      <% @sidebar.each do |section| %>
        <div class="mb-6">
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2"><%= section[:title] %></p>
          <ul class="space-y-1">
            <% section[:pages].each do |page| %>
              <li>
                <%= link_to page[:title],
                    docs_path(page[:path]),
                    class: "text-sm block py-0.5 leading-snug #{@current_path == page[:path] ? 'font-semibold text-black' : 'text-gray-500 hover:text-black'}" %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </nav>

  <%# Content %>
  <article class="min-w-0 flex-1 prose prose-sm prose-gray max-w-none
                  prose-headings:font-bold prose-headings:text-black
                  prose-a:text-black prose-a:underline
                  prose-code:bg-gray-100 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono
                  prose-pre:bg-gray-950 prose-pre:text-gray-100 prose-pre:rounded prose-pre:text-sm
                  prose-table:text-sm prose-th:text-left prose-th:font-semibold
                  prose-blockquote:border-l-2 prose-blockquote:border-gray-300 prose-blockquote:text-gray-500">
    <%= @content_html %>
  </article>

</div>
