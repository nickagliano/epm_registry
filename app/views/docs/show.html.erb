<% content_for :title, "#{@title} — EPS Docs" %>

<div class="max-w-6xl mx-auto px-4 py-8">

  <%# Mobile nav — collapsed horizontal scroll %>
  <div class="block sm:hidden mb-6 pb-4 border-b border-gray-200">
    <%= link_to "← Registry", root_path, class: "text-xs text-gray-400 hover:text-black block mb-3" %>
    <div class="flex gap-4 overflow-x-auto pb-1 text-sm">
      <% @sidebar.each do |section| %>
        <% section[:pages].each do |page| %>
          <%= link_to page[:title],
              docs_path(page[:path]),
              class: "shrink-0 py-0.5 #{@current_path == page[:path] ? 'font-semibold text-black' : 'text-gray-400 hover:text-black'}" %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="flex gap-10">

    <%# Desktop sidebar %>
    <nav class="hidden sm:block w-52 shrink-0">
      <div class="sticky top-8">
        <%= link_to "← Registry", root_path, class: "text-xs text-gray-400 hover:text-black mb-6 block" %>
        <% @sidebar.each do |section| %>
          <div class="mb-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2"><%= section[:title] %></p>
            <ul class="space-y-1">
              <% section[:pages].each do |page| %>
                <li>
                  <%= link_to page[:title],
                      docs_path(page[:path]),
                      class: "text-sm block py-0.5 leading-snug #{@current_path == page[:path] ? 'font-semibold text-black' : 'text-gray-500 hover:text-black'}" %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </nav>

    <%# Content %>
    <article class="docs-content min-w-0 flex-1">
      <%= @content_html %>
    </article>

  </div>
</div>

<style>
  .docs-content { font-size: 0.9rem; line-height: 1.7; color: #111; max-width: 680px; }
  .docs-content h1 { font-size: 1.6rem; font-weight: 700; margin: 0 0 1.2rem; }
  .docs-content h2 { font-size: 1.15rem; font-weight: 700; margin: 2rem 0 0.6rem; }
  .docs-content h3 { font-size: 1rem; font-weight: 600; margin: 1.5rem 0 0.4rem; }
  .docs-content p  { margin: 0 0 0.9rem; }
  .docs-content ul, .docs-content ol { margin: 0 0 0.9rem 1.4rem; }
  .docs-content ul { list-style: disc; }
  .docs-content ol { list-style: decimal; }
  .docs-content li { margin-bottom: 0.3rem; }
  .docs-content a  { text-decoration: underline; }
  .docs-content strong { font-weight: 600; }
  .docs-content em { font-style: italic; }
  .docs-content hr { border: none; border-top: 1px solid #e5e7eb; margin: 2rem 0; }
  .docs-content blockquote { border-left: 3px solid #d1d5db; padding-left: 1rem; color: #6b7280; margin: 0 0 0.9rem; }
  .docs-content code { background: #f3f4f6; padding: 0.1em 0.35em; border-radius: 3px; font-family: ui-monospace, monospace; font-size: 0.85em; }
  .docs-content pre  { background: #111; color: #e5e7eb; padding: 1rem 1.2rem; border-radius: 6px; overflow-x: auto; margin: 0 0 1rem; }
  .docs-content pre code { background: none; padding: 0; font-size: 0.82rem; color: inherit; }
  .docs-content table { width: 100%; border-collapse: collapse; margin: 0 0 1rem; font-size: 0.85rem; }
  .docs-content th  { text-align: left; font-weight: 600; border-bottom: 2px solid #e5e7eb; padding: 0.4rem 0.75rem 0.4rem 0; }
  .docs-content td  { border-bottom: 1px solid #f3f4f6; padding: 0.4rem 0.75rem 0.4rem 0; }
</style>
