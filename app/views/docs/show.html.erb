<% content_for :title, "#{@title} — EPS Docs" %>

<div class="max-w-6xl mx-auto py-8 w-full min-w-0">

  <%# Mobile nav — collapsed horizontal scroll %>
  <div class="block sm:hidden mb-6 pb-4 border-b border-base">
    <%= link_to "← Registry", root_path, class: "text-xs text-dim hover:text-base block mb-3" %>
    <div class="flex gap-4 overflow-x-auto pb-1 text-sm">
      <% @sidebar.each do |section| %>
        <% section[:pages].each do |page| %>
          <%= link_to page[:title],
              docs_path(page[:path]),
              class: "shrink-0 py-0.5 #{@current_path == page[:path] ? 'font-semibold text-base' : 'text-muted hover:text-base'}" %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="flex gap-10">

    <%# Desktop sidebar %>
    <nav class="hidden sm:block w-52 shrink-0">
      <div class="sticky top-8">
        <%= link_to "← Registry", root_path, class: "text-xs text-dim hover:text-base mb-6 block" %>
        <% @sidebar.each do |section| %>
          <div class="mb-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-dim mb-2"><%= section[:title] %></p>
            <ul class="space-y-1">
              <% section[:pages].each do |page| %>
                <li>
                  <%= link_to page[:title],
                      docs_path(page[:path]),
                      class: "text-sm block py-0.5 leading-snug #{@current_path == page[:path] ? 'font-semibold text-base' : 'text-muted hover:text-base'}" %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </nav>

    <%# Content %>
    <article class="docs-content min-w-0 flex-1">
      <%= @content_html %>
    </article>

  </div>
</div>
