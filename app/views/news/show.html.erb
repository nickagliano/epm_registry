<% content_for :title, "#{@post[:title]} — EPM News" %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <%= link_to "← News", news_index_path, class: "text-xs text-dim hover:text-base block mb-8" %>

  <p class="text-xs text-dim mb-2"><%= @post[:date].strftime("%B %-d, %Y") %></p>
  <h1 class="text-2xl font-bold mb-8"><%= @post[:title] %></h1>

  <article class="docs-content">
    <%= @post[:body_html] %>
  </article>
</div>
