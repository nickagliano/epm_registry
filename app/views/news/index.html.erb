<% content_for :title, "News — EPM" %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold mb-8">News</h1>

  <% if @posts.empty? %>
    <p class="text-gray-500 text-sm">Nothing yet.</p>
  <% else %>
    <div class="divide-y divide-gray-200">
      <% @posts.each do |post| %>
        <div class="py-6">
          <p class="text-xs text-gray-400 mb-1"><%= post[:date].strftime("%B %-d, %Y") %></p>
          <h2 class="text-lg font-semibold mb-2">
            <%= link_to post[:title], news_path(post[:slug]), class: "hover:underline" %>
          </h2>
          <p class="text-sm text-gray-600">
            <%= link_to "Read →", news_path(post[:slug]), class: "text-black hover:underline text-sm" %>
          </p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
